{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Plugin Tester",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-tester",
            "program": "${workspaceFolder}/src/Famick.HomeManagement.Plugin.Tester/bin/Debug/net10.0/Famick.HomeManagement.Plugin.Tester.dll",
            "args": ["--config", "${input:configPath}"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        }
    ],
    "inputs": [
        {
            "id": "configPath",
            "type": "promptString",
            "description": "Path to plugins.json config file",
            "default": "plugins.json"
        }
    ]
}
